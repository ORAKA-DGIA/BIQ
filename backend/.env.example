# Django
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=your-railway-app.up.railway.app,localhost,127.0.0.1

# Database — Railway sets this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — set to your GitHub Pages URL
CORS_ALLOWED_ORIGINS=https://yourusername.github.io

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
